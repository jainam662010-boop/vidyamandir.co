          "titleHi": "वास्तविक संख्याएँ",
          "duration": "45 min",
          "lessons": [
            { "id": "l1", "title": "Introduction & Euclid's Lemma", "videoId": "ySWSfMiFoFk", "duration": "12:30" },
            { "id": "l2", "title": "Fundamental Theorem of Arithmetic", "videoId": "p3MVgVTj9Vs", "duration": "18:45" }
          ],
          "ncertTopics": [
            { "text": "Euclid's Division Lemma: a = bq + r, 0 ≤ r < b", "marks": "3", "important": true, "type": "theorem" },
            { "text": "Fundamental Theorem of Arithmetic — Unique Prime Factorization", "marks": "3", "important": true, "type": "theorem" },
            { "text": "Proof that √2, √3 are irrational numbers", "marks": "3", "important": true, "type": "proof" },
            { "text": "HCF and LCM using prime factorization", "marks": "2", "important": true, "type": "concept" },
            { "text": "Decimal expansions of rational numbers (terminating / non-terminating)", "marks": "2", "important": false, "type": "concept" }
          ],
          "notes": {
            "content": [
              { "type": "intro", "text": "Real numbers include all rational and irrational numbers. This chapter lays the foundation for all of Number Theory in Class 10." },
              { "type": "heading", "text": "Euclid's Division Lemma" },
              { "type": "text", "text": "For positive integers a and b, there exist unique integers q and r such that:\na = bq + r,  where 0 ≤ r < b" },
              { "type": "formula", "text": "a = bq + r  →  HCF(a,b) = HCF(b,r)" },
              { "type": "keypoint", "text": "Every composite number can be expressed as a product of primes in a unique way (Fundamental Theorem of Arithmetic)." },
              { "type": "heading", "text": "Irrational Numbers" },
              { "type": "text", "text": "Numbers that cannot be written as p/q. Examples: √2, √3, √5, π, e" },
              { "type": "keypoint", "text": "If p is a prime and p divides a², then p divides a (Key lemma for irrationality proofs)." },
              { "type": "example", "question": "Find HCF of 135 and 225 using Euclid's algorithm.", "answer": "225 = 135×1 + 90\n135 = 90×1 + 45\n90 = 45×2 + 0\n∴ HCF = 45" }
            ]
          },
          "quiz": [
            { "q": "Euclid's Division Lemma: a = bq + r where r satisfies:", "options": ["0 ≤ r < b", "r > b", "r = 0", "r ≥ b"], "answer": 0 },
            { "q": "Which of the following is irrational?", "options": ["√4", "0.125", "√2", "22/7"], "answer": 2 },
            { "q": "HCF of 12 and 18 using prime factorization:", "options": ["2", "6", "36", "3"], "answer": 1 },
            { "q": "Decimal expansion of 17/8 is:", "options": ["Non-terminating repeating", "Terminating", "Non-terminating non-repeating", "None"], "answer": 1 }
          ],
          "teachers": [{ "name": "Vedantu Math", "channel": "Vedantu", "avatar": "V", "color": "#D4A017" }]
