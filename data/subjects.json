          "notes": {
            "content": [
              { "type": "intro", "text": "Trigonometry: the study of relationships between sides and angles of right triangles." },
              { "type": "heading", "text": "Ratios in Right △ABC (right angle at B)" },
              { "type": "formula", "text": "sinA = BC/AC   cosA = AB/AC   tanA = BC/AB\ncosecA = AC/BC  secA = AC/AB  cotA = AB/BC" },
              { "type": "heading", "text": "Standard Values Table" },
              { "type": "text", "text": "Angle:  0°   30°   45°   60°   90°\nsin:    0    1/2   1/√2  √3/2   1\ncos:    1   √3/2  1/√2   1/2   0\ntan:    0   1/√3   1     √3   undef" },
              { "type": "keypoint", "text": "sin²θ + cos²θ = 1 (most frequently used identity in board exams)" },
              { "type": "example", "question": "Tower height if angle of elevation is 60° from 20m away.", "answer": "height = 20 × tan60° = 20√3 m ≈ 34.64 m" }
            ]
          },
