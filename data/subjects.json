          "ncertTopics": [
            { "text": "Basic Proportionality Theorem (Thales Theorem) and its converse", "marks": "3", "important": true, "type": "theorem" },
            { "text": "Criteria of similarity: AA, SAS, SSS", "marks": "3", "important": true, "type": "theorem" },
            { "text": "Ratio of areas of similar triangles = square of ratio of sides", "marks": "3", "important": true, "type": "theorem" },
            { "text": "Pythagoras Theorem proof and converse", "marks": "5", "important": true, "type": "proof" }
          ],
          "notes": {
            "content": [
              { "type": "intro", "text": "Two triangles are similar if corresponding angles are equal and sides are proportional." },
              { "type": "heading", "text": "Basic Proportionality Theorem (BPT)" },
              { "type": "text", "text": "If DE ∥ BC in △ABC, then AD/DB = AE/EC" },
              { "type": "formula", "text": "ar(△ABC)/ar(△DEF) = (AB/DE)² = (BC/EF)² = (AC/DF)²" },
              { "type": "keypoint", "text": "Pythagoras: In a right triangle, hypotenuse² = sum of squares of other two sides." }
            ]
          },
          "quiz": [
            { "q": "BPT is also known as:", "options": ["Pythagoras Theorem", "Thales Theorem", "Midpoint Theorem", "Angle Bisector Theorem"], "answer": 1 },
            { "q": "Ratio of areas of similar triangles with sides ratio 2:3:", "options": ["2:3", "4:9", "8:27", "6:9"], "answer": 1 },
            { "q": "In △ABC, if DE ∥ BC and AD = 3, DB = 5, AE = 6, then EC =", "options": ["8", "10", "12", "9"], "answer": 1 }
          ],
          "teachers": [{ "name": "Doubtnut", "channel": "Doubtnut", "avatar": "D", "color": "#5A8FAA" }]
