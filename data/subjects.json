            { "text": "Cross-multiplication method", "marks": "3", "important": true, "type": "method" },
            { "text": "Consistency conditions: a₁/a₂, b₁/b₂, c₁/c₂ ratios", "marks": "3", "important": true, "type": "concept" },
            { "text": "Word problems on age, coins, fraction, geometry, speed", "marks": "5", "important": true, "type": "application" }
          ],
